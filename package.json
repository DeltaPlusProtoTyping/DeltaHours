{
  "name": "deltahours",
  "version": "1.0.0",
  "description": "Track billable hours per job — autosaved to JSON, adjustable themes",
  "main": "dist/main/main.js",
  "author": "DeltaPlusProtoTyping",
  "license": "MIT",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.deltaplusprototyping.deltahours",
    "productName": "DeltaHours",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3"
  }
}
